{
  "name": "unifyvault-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "UnifyVault Protocol Monorepo",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --filter=@unifyvault/web",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md,sol,yml,yaml}\"",
    "prepare": "husky install"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.3.0",
    "@commitlint/config-conventional": "^19.2.2",
    "eslint": "^10.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.7",
    "prettier": "^3.3.2",
    "prettier-plugin-solidity": "^2.3.1",
    "turbo": "^2.0.4",
    "typescript": "^5.4.5"
  },
  "lint-staged": {
    "*.{ts,tsx,js,json,sol,md,yml,yaml}": "prettier --write",
    "*.{ts,tsx,js}": "eslint --fix"
  },
  "packageManager": "pnpm@9.4.0"
}
